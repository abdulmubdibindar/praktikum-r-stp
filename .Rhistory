tingkat_semester,
"Semester 1 & 2" = "1 (Semester 1 – Semester 2)",
"Semester 3 & 4" = "2 (Semester 3 – Semester 4)",
"Semester 5 & 6" = "3 (Semester 5 - Semester 6)",
"Semester 7 & 8" = "4 (Semester 7 - Semester 8)"
)
)
